__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# Environment
.env
.env.local

# IDEs
.vscode/
.idea/
*.swp

